# Supabase 연결 정보 (Supabase 프로젝트 설정 > API 에서 확인)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# 사이트 URL (로컬: http://localhost:3000, 프로덕션: https://your-domain.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend 이메일 발송 (https://resend.com/api-keys)
RESEND_API_KEY=

# 발신자 이메일 (Resend 도메인 인증 후 변경)
RESEND_FROM_EMAIL=noreply@moida.example
